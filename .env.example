# AI generator (optional). Without a key, the generator falls back to
# deterministic rule-based grouping — everything still works, just less polished.
#
# Set ONE provider. Add the matching key in Vercel → Project → Settings →
# Environment Variables (do NOT commit real keys).

# --- Option A: Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001   # optional override

# --- Option B: OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini                 # optional override


# Rate limiting + cache (optional). Without these, an in-memory per-instance
# limiter/cache is used — fine for low traffic, but shared limits across
# serverless instances require Upstash Redis (REST). Create a free DB at
# upstash.com and paste its REST URL + token.

# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
